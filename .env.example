# .env.example
# Copy to .env and fill in values.
# No API tokens needed — Slack and Asana credentials are handled by their MCP servers.
# See README.md for MCP setup instructions.

# ─── User Identity ────────────────────────────────────────────────────────────
# Your full name — used to resolve your Slack ID at runtime if SLACK_USER_ID is blank
USER_NAME=

# Your Slack member ID (e.g. U01ABC123).
# Optional — resolved automatically at runtime via the Slack MCP if blank.
SLACK_USER_ID=

# Your Asana user GID.
# Optional — resolved automatically at runtime via the Asana MCP if blank.
ASANA_USER_ID=

# Asana project GID to scan for assigned tickets
ASANA_PROJECT_ID=1213494960962920

# ─── Runtime Settings ─────────────────────────────────────────────────────────
# How many days back to scan Slack (also the minimum when no previous run exists)
LOOKBACK_DAYS=3

# Comma-separated channel name prefixes to include as customer channels
CHANNEL_PREFIXES=ext-,airops-,ext-airops-

# Comma-separated Asana ticket name substrings to always skip for stale nudges
STALE_TICKET_SKIP=

# Absolute path where dashboard_data.json should be written
# e.g. /Users/you/Documents/dashboard_data.json
DASHBOARD_OUTPUT_PATH=
