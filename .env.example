# .env.example
# Copy this file to .env, fill in all values, and add .env to .gitignore.
# All workflows and CLAUDE.md read credentials from here — never hardcode them elsewhere.

# ─── User Identity ────────────────────────────────────────────────────────────
# Your full name — used to resolve your Slack ID at runtime if SLACK_USER_ID is blank
USER_NAME=

# Your work email
USER_EMAIL=

# Your Slack member ID (e.g. U01ABC123).
# If left blank, the agent resolves it at runtime via slack_search_users using USER_NAME.
# Find it: Slack → your profile → ⋯ → Copy member ID
SLACK_USER_ID=

# Your Asana user GID.
# Find it: https://app.asana.com/api/1.0/users/me (look for "gid")
ASANA_USER_ID=

# Asana project GID to scan for assigned tickets
ASANA_PROJECT_ID=1213494960962920

# ─── Slack API ────────────────────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...) — for channel reads
# Create at: https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-

# User OAuth Token (xoxp-...) — required for search:read.private
# Required scopes: search:read, channels:history, groups:history, im:history,
#                  users:read, users:read.email, reactions:read, files:read
SLACK_USER_TOKEN=xoxp-

# Base URL of your Slack workspace
SLACK_WORKSPACE_URL=https://teamairops.slack.com

# ─── Asana API ────────────────────────────────────────────────────────────────
# Personal Access Token — create at: https://app.asana.com/0/my-apps
ASANA_PAT=

# Asana API base URL (no trailing slash)
ASANA_BASE_URL=https://app.asana.com/api/1.0

# ─── Runtime Settings ─────────────────────────────────────────────────────────
# How many days back to scan Slack (also the minimum when no previous run exists)
LOOKBACK_DAYS=3

# Comma-separated channel name prefixes to include as customer channels
CHANNEL_PREFIXES=ext-,airops-,ext-airops-

# Emoji names that count as a resolution signal (from the user's Slack account)
RESOLUTION_EMOJIS=white_check_mark,thumbsup,pray,tada,heavy_check_mark,100,raised_hands

# Comma-separated Asana ticket name substrings to always skip for stale nudges
STALE_TICKET_SKIP=Lotus

# Absolute path where dashboard_data.json should be written
# e.g. /Users/you/Documents/Claude/Scheduled/customer-slack-to-asana-daily/dashboard_data.json
DASHBOARD_OUTPUT_PATH=
